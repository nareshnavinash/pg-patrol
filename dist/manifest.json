{
  "manifest_version": 3,
  "name": "PG Patrol",
  "version": "1.0.0",
  "description": "Family-friendly web filter — replaces swear words with funny alternatives and detects NSFW images",
  "permissions": [
    "storage",
    "activeTab",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "src/assets/icons/icon-16.png",
      "32": "src/assets/icons/icon-32.png",
      "48": "src/assets/icons/icon-48.png",
      "128": "src/assets/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "src/assets/icons/icon-16.png",
    "32": "src/assets/icons/icon-32.png",
    "48": "src/assets/icons/icon-48.png",
    "128": "src/assets/icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/pre-blur.ts-DCAbtoWW.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_start"
    },
    {
      "js": [
        "assets/index.ts-loader-Dv8BD5T3.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_end"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "src/assets/cartoons/*",
        "assets/models/*",
        "assets/ml-models/**/*",
        "filter-worker.js",
        "assets/pre-blur.ts-DCAbtoWW.js",
        "assets/negative-news-words-CYoML0CM.js",
        "assets/storage-BqH49hLa.js",
        "assets/word-list-updater-DKeYspeL.js",
        "assets/types-BYz9lFZ3.js",
        "assets/nsfw-preprocessing-CNcnUBRi.js",
        "assets/negative-news-engine-BvxgD6EN.js",
        "assets/index.ts-D59nb2lE.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
