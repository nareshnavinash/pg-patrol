{
  "name": "pg-patrol",
  "version": "1.0.0",
  "description": "PG Patrol — Family-friendly web filter that replaces swear words and NSFW images",
  "private": true,
  "type": "module",
  "author": "Naresh Navinash",
  "license": "MIT",
  "homepage": "https://github.com/nareshnavinash/pg-patrol",
  "repository": {
    "type": "git",
    "url": "https://github.com/nareshnavinash/pg-patrol.git"
  },
  "bugs": {
    "url": "https://github.com/nareshnavinash/pg-patrol/issues"
  },
  "keywords": [
    "chrome-extension",
    "firefox-addon",
    "parental-controls",
    "web-filter",
    "profanity-filter",
    "nsfw-blocker",
    "content-filter",
    "family-safety",
    "browser-extension",
    "manifest-v3",
    "privacy",
    "on-device-ai"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:chrome": "tsc && vite build",
    "build:firefox": "tsc && vite build --config vite.config.firefox.ts",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "package": "npm run build:chrome && cd dist && zip -r ../pg-patrol-chrome.zip . && cd ..",
    "package:chrome": "npm run build:chrome && cd dist && zip -r ../pg-patrol-chrome.zip . && cd ..",
    "package:firefox": "npm run build:firefox && cd dist-firefox && zip -r ../pg-patrol-firefox.zip . && cd ..",
    "firefox:dev": "npm run build:firefox && npx web-ext run --source-dir dist-firefox/",
    "clean": "rm -rf dist dist-firefox pg-patrol-chrome.zip pg-patrol-firefox.zip",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@2toad/profanity": "^3.0.0",
    "@huggingface/transformers": "^3.8.1",
    "onnxruntime-web": "^1.24.3",
    "preact": "^10.29.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.27",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.48.0",
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/preact": "^3.2.4",
    "@types/chrome": "^0.0.287",
    "@types/jest": "^29.5.0",
    "@types/webextension-polyfill": "^0.12.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.4.0",
    "web-ext": "^8.4.0"
  }
}
