{
  "name": "pg-patrol-video",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "studio": "remotion studio src/index.ts",
    "render:video": "remotion render src/index.ts LaunchVideo out/pg-patrol-launch.mp4 --image-format=png",
    "render:banner-frames": "remotion render src/index.ts Banner --image-format=png --sequence --output-location=out/banner-frames",
    "generate-audio": "bash scripts/generate-audio.sh"
  },
  "dependencies": {
    "@remotion/cli": "4.0.242",
    "@remotion/media-utils": "4.0.242",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "4.0.242"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.7.0"
  }
}
